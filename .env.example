# LINE Messaging API（在 LINE Developers Console > 你的 Channel > Messaging API 分頁取得）
LINE_CHANNEL_ACCESS_TOKEN=
LINE_CHANNEL_SECRET=

# Google 服務帳戶（在 Google Cloud Console 建立 Service Account 並下載 JSON 金鑰後填入）
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=

# 要寫入的 Google Sheet ID（試算表網址中 /d/ 與 /edit 之間那段）
GOOGLE_SHEET_ID=
GOOGLE_SHEET_NAME=記帳

# 伺服器埠號
PORT=3000
